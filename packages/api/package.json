{
  "name": "@unveiled/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./worker": "./src/worker.ts",
    "./openapi": "./src/openapi.ts",
    "./data-access": "./src/data-access/index.ts",
    "./data-access/*": "./src/data-access/*.ts",
    "./handlers/*": "./src/handlers/*.ts",
    "./generated": "./src/generated.ts",
    "./admin-operations": "./src/admin-operations.ts",
    "./assets/*": "./src/assets/*.ts",
    "./auth-account-actions": "./src/auth-account-actions.ts",
    "./auth-forms": "./src/auth-forms.ts",
    "./auth-profile": "./src/auth-profile.ts",
    "./db/*": "./src/db/*.ts",
    "./env": "./src/env.ts",
    "./env.ts": "./src/env.ts",
    "./forms/*": "./src/forms/*.ts",
    "./i18n": "./src/i18n.ts",
    "./middleware/*": "./src/middleware/*.ts",
    "./payments/*": "./src/payments/*.ts",
    "./routes/*": "./src/routes/*.ts",
    "./unveiled-view-models": "./src/unveiled-view-models.ts"
  },
  "scripts": {
    "dev": "wrangler dev -c ../../wrangler.api.toml --port 8787 ${WRANGLER_REMOTE:+--remote}",
    "build": "bun run scripts/build.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "biome check .",
    "test:unit": "bun test src/**/*.test.ts",
    "test:integration": "bun test tests/integration/**/*.test.ts",
    "openapi:gen": "bun run src/openapi.ts",
    "openapi:check": "bun run scripts/openapi-check.ts"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@hono/zod-openapi": "^1.4.0",
    "@neondatabase/serverless": "^1.1.0",
    "@unveiled/app": "workspace:*",
    "better-auth": "^1.6.9",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.14",
    "js-yaml": "^4.2.0",
    "stripe": "^22.1.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260506.1",
    "@hono/node-server": "^1.13.7",
    "@types/bun": "^1.3.13",
    "esbuild": "^0.25.0"
  }
}

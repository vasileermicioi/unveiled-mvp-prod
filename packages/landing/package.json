{
  "name": "@unveiled/landing",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*"
  },
  "scripts": {
    "dev": "astro dev --port 4322",
    "build": "astro build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "biome check .",
    "test:unit": "bun test --pass-with-no-tests src/",
    "preview": "astro preview --port 4322",
    "preview:cloudflare": "wrangler dev --config ../../wrangler.landing.toml",
    "astro": "astro",
    "astro-check-proxied": "astro check"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.3.1",
    "@astrojs/react": "^5.0.4",
    "@tailwindcss/vite": "^4.2.4",
    "@unveiled/design-system": "workspace:*",
    "astro": "^6.1.9",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@cloudflare/workers-types": "^4.20260506.1",
    "@types/bun": "^1.3.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3"
  }
}

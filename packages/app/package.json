{
  "name": "@unveiled/app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*"
  },
  "scripts": {
    "dev": "astro dev --base /app --port 4321",
    "build": "astro build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "biome check .",
    "test:unit": "bun test src/**/*.test.ts",
    "preview": "astro preview",
    "preview:cloudflare": "wrangler dev --config ../../wrangler.app.toml",
    "astro": "astro",
    "astro-check-proxied": "astro check",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "drizzle-kit migrate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed:operations-smoke": "bun ../../scripts/seed-operations-smoke.ts"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.3.1",
    "@astrojs/react": "^5.0.4",
    "@hookform/resolvers": "^5.2.2",
    "@neondatabase/serverless": "^1.1.0",
    "@nextui-org/react": "^2.6.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@stripe/stripe-js": "^9.4.0",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-query": "^5.100.5",
    "@unveiled/api": "workspace:*",
    "@unveiled/design-system": "workspace:*",
    "astro": "^6.1.9",
    "better-auth": "^1.6.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.11.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.75.0",
    "stripe": "^22.1.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@cloudflare/workers-types": "^4.20260506.1",
    "@types/bun": "^1.3.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10"
  }
}

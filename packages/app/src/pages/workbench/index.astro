---
import { Button } from "@unveiled/design-system";
import { WorkbenchClient } from "~/components/examples/workbench-client";
import BaseLayout from "~/layouts/base-layout.astro";
import { loadPublicDiscoveryData } from "~/lib/data-access/loaders";

const initialDiscovery = await loadPublicDiscoveryData();
---

<BaseLayout title="Workbench">
  <main class="mx-auto grid min-h-screen w-full max-w-6xl gap-8 px-6 py-10">
    <nav class="flex items-center justify-between border-b pb-4">
      <a href="/" class="text-sm font-semibold tracking-wide">Unveiled MVP</a>
      <Button asChild variant="outline" size="sm">
        <a href="/">Home</a>
      </Button>
    </nav>

    <header class="grid gap-3">
      <p class="text-sm font-medium text-muted-foreground">Astro pages as Storybook alternative</p>
      <h1 class="text-3xl font-semibold md:text-5xl">Workbench</h1>
    </header>

    <section class="grid gap-4 rounded-lg border bg-card p-5">
      <h2 class="text-base font-semibold">Button variants</h2>
      <div class="flex flex-wrap gap-3">
        <Button>Default</Button>
        <Button variant="secondary">Secondary</Button>
        <Button variant="outline">Outline</Button>
        <Button variant="ghost">Ghost</Button>
        <Button variant="destructive">Destructive</Button>
      </div>
    </section>

    <WorkbenchClient client:load initialDiscovery={initialDiscovery} />
  </main>
</BaseLayout>

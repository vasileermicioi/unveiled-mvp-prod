---
import { VisualSystemApp } from "~/components/unveiled/visual-system-app";
import BaseLayout from "~/layouts/base-layout.astro";
import { createShellFromViewer } from "~/lib/auth-display";
import { getAuthRedirectPath, getViewer } from "~/lib/auth-profile";
import { loadPublicDiscoveryData } from "~/lib/data-access/loaders";
import { createPublicInitialSurfaceData } from "~/lib/data-access/surface-data";
import { normalizeLanguage } from "~/lib/i18n";
import { parseSafeRedirectTarget } from "~/lib/product-routes";

const lang = normalizeLanguage(Astro.params.lang?.toUpperCase());

const viewer = await getViewer(Astro.request, { guestLanguage: lang });
viewer.language = lang;

let redirectTarget = "";
if (viewer.kind === "authenticated") {
  const redirectParam = Astro.url.searchParams.get("redirect");
  const safeRedirect = parseSafeRedirectTarget(redirectParam, lang);
  redirectTarget = `/${lang.toLowerCase()}${getAuthRedirectPath(viewer, safeRedirect?.path ?? null)}`;
}

if (redirectTarget) {
  return Astro.redirect(redirectTarget);
}

const redirectParam = Astro.url.searchParams.get("redirect");
const safeRedirect = parseSafeRedirectTarget(redirectParam, lang);
const callbackURL = safeRedirect
  ? `/${lang.toLowerCase()}${safeRedirect.path}`
  : `/${lang.toLowerCase()}/`;

const initialShell = createShellFromViewer(viewer, "landing");
const initialDiscovery = createPublicInitialSurfaceData(
  await loadPublicDiscoveryData({}, undefined, viewer.language),
);
---

<BaseLayout title="Login | Unveiled" lang={lang}>
  <VisualSystemApp
    client:load
    initialShell={initialShell}
    initialDiscovery={initialDiscovery}
    initialView="landing"
    callbackURL={callbackURL}
    initialMode="login"
  />
</BaseLayout>

---
import BaseLayout from "~/layouts/base-layout.astro";
import { getViewer } from "~/lib/auth-profile";
import { copyFor, normalizeLanguage } from "~/lib/i18n";

const lang = normalizeLanguage(Astro.params.lang?.toUpperCase());
const { partnerId } = Astro.params;
const token = Astro.url.searchParams.get("token") ?? "";
const viewer = await getViewer(Astro.request, {
  repairMissingProfile: false,
  guestLanguage: lang,
});
viewer.language = lang;
const isGuest = viewer.kind === "guest";
const copy = copyFor(lang).venueCheckIn;
---

<BaseLayout title={copy.eyebrow} lang={lang}>
  <main class="mx-auto flex min-h-screen max-w-xl flex-col justify-center px-6 py-12">
    <section id="check-in-card" class="border-4 border-brand-dark bg-white p-6 shadow-[8px_8px_0_var(--color-brand-dark)]">
      <p class="text-xs font-black uppercase tracking-widest text-brand-dark/60">
        {copy.eyebrow}
      </p>
      <h1 class="mt-4 font-black text-3xl uppercase tracking-normal">
        {isGuest ? copy.guestHeading : copy.authHeading}
      </h1>
      <p class="mt-4 text-sm font-bold uppercase tracking-widest text-brand-dark/70">
        {isGuest ? copy.guestMessage : copy.authMessage}
      </p>
      {
        isGuest ? (
          <a
            class="mt-6 inline-flex border-4 border-brand-dark bg-brand-yellow px-5 py-3 font-black text-sm uppercase tracking-widest text-brand-dark"
            href={`/${lang.toLowerCase()}/?callbackURL=${encodeURIComponent(`/${lang.toLowerCase()}/venue-check-in/${partnerId}?token=${token}`)}`}
          >
            {copy.continueSignIn}
          </a>
        ) : (
          <form class="mt-6" method="POST" data-venue-check-in-form>
            <input name="partnerId" type="hidden" value={partnerId} />
            <input name="venueToken" type="hidden" value={token} />
            <button
              class="border-4 border-brand-dark bg-brand-dark px-5 py-3 font-black text-sm uppercase tracking-widest text-white cursor-pointer hover:bg-brand-dark/90"
              type="submit"
            >
              {copy.checkIn}
            </button>
            <p
              class="mt-4 text-xs font-black uppercase tracking-widest"
              data-venue-check-in-status
            >
              {copy.ready}
            </p>
          </form>
        )
      }
    </section>

    <!-- SUCCESS SCREEN -->
    <div
      id="check-in-success-screen"
      class="hidden flex-col items-center text-center p-8 border-4 border-brand-dark bg-[#35c46b] text-brand-dark space-y-6 shadow-[8px_8px_0_var(--color-brand-dark)]"
    >
      <div class="inline-flex size-24 items-center justify-center border-4 border-brand-dark bg-white shadow-[6px_6px_0_0_#202621]">
        <svg class="size-16 text-[#35c46b]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="4">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
      </div>
      <div class="space-y-2">
        <h2 class="font-display text-4xl font-black uppercase leading-none tracking-wider">
          VALID TICKET
        </h2>
        <p class="text-xs font-black uppercase tracking-[0.2em] opacity-80">
          Einlass Gewährt / Entry Allowed
        </p>
      </div>
      <p
        id="success-screen-message"
        class="w-full border-4 border-brand-dark bg-white px-4 py-3 font-display text-lg font-black uppercase tracking-wider shadow-[4px_4px_0_0_#202621]"
      >
      </p>
    </div>

    <!-- WARNING SCREEN (ALREADY USED) -->
    <div
      id="check-in-warning-screen"
      class="hidden flex-col items-center text-center p-8 border-4 border-brand-dark bg-brand-yellow text-brand-dark space-y-6 shadow-[8px_8px_0_var(--color-brand-dark)]"
    >
      <div class="inline-flex size-24 items-center justify-center border-4 border-brand-dark bg-white shadow-[6px_6px_0_0_#202621]">
        <svg class="size-16 text-brand-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
        </svg>
      </div>
      <div class="space-y-2">
        <h2 class="font-display text-3xl font-black uppercase leading-none tracking-wider">
          DOUBLE SCAN
        </h2>
        <p class="text-xs font-black uppercase tracking-[0.2em] opacity-80">
          Doppelt Entwertet / Duplicate Scan
        </p>
      </div>
      <p
        id="warning-screen-message"
        class="w-full border-4 border-brand-dark bg-white px-4 py-3 font-display text-lg font-black uppercase tracking-wider shadow-[4px_4px_0_0_#202621]"
      >
      </p>
    </div>

    <!-- FAILED SCREEN (INVALID/EXPIRED) -->
    <div
      id="check-in-failed-screen"
      class="hidden flex-col items-center text-center p-8 border-4 border-brand-dark bg-[#ff5f57] text-brand-dark space-y-6 shadow-[8px_8px_0_var(--color-brand-dark)]"
    >
      <div class="inline-flex size-24 items-center justify-center border-4 border-brand-dark bg-white shadow-[6px_6px_0_0_#202621]">
        <svg class="size-16 text-[#ff5f57]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="4">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </div>
      <div class="space-y-2">
        <h2 class="font-display text-4xl font-black uppercase leading-none tracking-wider">
          INVALID TICKET
        </h2>
        <p class="text-xs font-black uppercase tracking-[0.2em] opacity-80">
          Einlass Abgelehnt / Entry Denied
        </p>
      </div>
      <p
        id="failed-screen-message"
        class="w-full border-4 border-brand-dark bg-white px-4 py-3 font-display text-lg font-black uppercase tracking-wider shadow-[4px_4px_0_0_#202621]"
      >
      </p>
    </div>
  </main>
  <script is:inline define:vars={{ lang }}>
    const isGerman = lang === "DE";
    const checkingInText = isGerman ? "Checke ein..." : "Checking in...";
    const checkInFailedText = isGerman ? "Check-in failed." : "Check-in failed.";
  </script>
  <script>
    import { actions } from "astro:actions";

    const card = document.getElementById("check-in-card");
    const form = document.querySelector("[data-venue-check-in-form]");
    const status = document.querySelector("[data-venue-check-in-status]");
    // Declare dynamic variables compiled from define:vars above
    declare const checkingInText: string;
    declare const checkInFailedText: string;

    form?.addEventListener("submit", (event) => {
      event.preventDefault();
      const formData = new FormData(form as HTMLFormElement);
      const partnerId = String(formData.get("partnerId") || "");
      const venueToken = String(formData.get("venueToken") || "");
      if (status) status.textContent = checkingInText;
      void actions
         .checkInWithVenueQr({ partnerId, venueToken })
         .then((result: { data?: { ok?: boolean; data?: { alreadyCheckedIn?: boolean }; notice?: { message?: string }; formError?: string } }) => {
           if (card) card.classList.add("hidden");

           if (result.data?.ok) {
             const data = result.data.data;
             const isWarning = data?.alreadyCheckedIn;
             const msg = result.data.notice?.message || "Success";

             if (isWarning) {
               const warningScreen = document.getElementById("check-in-warning-screen");
               const warningMsg = document.getElementById("warning-screen-message");
               if (warningMsg) warningMsg.textContent = msg;
               warningScreen?.classList.remove("hidden");
               warningScreen?.classList.add("flex");
             } else {
               const successScreen = document.getElementById("check-in-success-screen");
               const successMsg = document.getElementById("success-screen-message");
               if (successMsg) successMsg.textContent = msg;
               successScreen?.classList.remove("hidden");
               successScreen?.classList.add("flex");
             }
           } else {
             const errorMsg = result.data?.formError || checkInFailedText;
             const failedScreen = document.getElementById("check-in-failed-screen");
             const failedText = document.getElementById("failed-screen-message");
             if (failedText) failedText.textContent = errorMsg;
             failedScreen?.classList.remove("hidden");
             failedScreen?.classList.add("flex");
           }
         })
         .catch(() => {
           if (card) card.classList.add("hidden");
           const failedScreen = document.getElementById("check-in-failed-screen");
           const failedText = document.getElementById("failed-screen-message");
           if (failedText) failedText.textContent = checkInFailedText;
           failedScreen?.classList.remove("hidden");
           failedScreen?.classList.add("flex");
         });
    });
  </script>
</BaseLayout>

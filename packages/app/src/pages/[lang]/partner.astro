---
import { VisualSystemApp } from "~/components/unveiled/visual-system-app";
import BaseLayout from "~/layouts/base-layout.astro";
import { createShellFromViewer } from "~/lib/auth-display";
import { getViewer } from "~/lib/auth-profile";
import { loadCurrentPartnerData } from "~/lib/data-access/loaders";
import { createPartnerInitialSurfaceData } from "~/lib/data-access/surface-data";
import { normalizeLanguage } from "~/lib/i18n";
import { productRoutes, resolveRouteOwnership } from "~/lib/product-routes";

const lang = normalizeLanguage(Astro.params.lang?.toUpperCase());

const viewer = await getViewer(Astro.request, { guestLanguage: lang });
viewer.language = lang;

const ownership = resolveRouteOwnership(viewer, productRoutes.partner);
if (!ownership.ok) {
  const redirectUrl = ownership.redirectTo.startsWith("/")
    ? `/${lang.toLowerCase()}${ownership.redirectTo}`
    : `/${lang.toLowerCase()}/${ownership.redirectTo}`;
  return Astro.redirect(redirectUrl, ownership.status);
}

const initialShell = createShellFromViewer(
  ownership.viewer,
  ownership.route.id,
);
const initialDiscovery = createPartnerInitialSurfaceData(
  ownership.viewer,
  await loadCurrentPartnerData(ownership.viewer),
);
---

<BaseLayout title="Partner | Unveiled" lang={lang}>
  <VisualSystemApp client:load initialShell={initialShell} initialDiscovery={initialDiscovery} initialView="partner" />
</BaseLayout>

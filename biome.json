{
  "$schema": "https://biomejs.dev/schemas/2.4.13/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": false,
    "includes": [
      "**",
      "!dist",
      "!.astro",
      "!.wrangler",
      "!node_modules",
      "!drizzle",
      "!_old_app",
      "!architecture",
      "!src/lib/generated",
      "!src/styles/generated",
      "!.storybook",
      "!packages/*/dist",
      "!packages/*/.astro",
      "!packages/*/node_modules",
      "!packages/*/coverage"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "overrides": [
    {
      "includes": ["**/*.astro"],
      "linter": {
        "enabled": false
      }
    },
    {
      "includes": ["src/**/*.{ts,tsx}"],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "error"
          }
        }
      }
    },
    {
      "includes": [
        "src/lib/logger.ts",
        "src/lib/logger.test.ts",
        "src/components/**",
        "src/layouts/**",
        "**/*.test.ts",
        "**/*.integration.test.ts",
        "**/*.stories.tsx",
        "**/*.stories.ts",
        "scripts/**",
        "tests/**",
        "packages/orchestrator/src/worker.ts",
        "packages/orchestrator/src/logging.ts",
        "packages/orchestrator/src/dev-server.ts",
        "packages/orchestrator/src/readiness.ts",
        "packages/orchestrator/scripts/**",
        "packages/orchestrator/vite.config.ts"
      ],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "off"
          }
        }
      }
    }
  ]
}

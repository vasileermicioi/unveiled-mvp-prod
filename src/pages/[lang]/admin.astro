---
import { VisualSystemApp } from "@/components/unveiled/visual-system-app";
import BaseLayout from "@/layouts/base-layout.astro";
import { createShellFromViewer } from "@/lib/auth-display";
import { getViewer } from "@/lib/auth-profile";
import { loadAdminData } from "@/lib/data-access/loaders";
import { createAdminInitialSurfaceData } from "@/lib/data-access/surface-data";
import { normalizeLanguage } from "@/lib/i18n";
import { productRoutes, resolveRouteOwnership } from "@/lib/product-routes";

const lang = normalizeLanguage(Astro.params.lang?.toUpperCase());

const viewer = await getViewer(Astro.request, { guestLanguage: lang });
viewer.language = lang;

const ownership = resolveRouteOwnership(viewer, productRoutes.admin);
if (!ownership.ok) {
  const redirectUrl = ownership.redirectTo.startsWith("/")
    ? `/${lang.toLowerCase()}${ownership.redirectTo}`
    : `/${lang.toLowerCase()}/${ownership.redirectTo}`;
  return Astro.redirect(redirectUrl, ownership.status);
}

const initialShell = createShellFromViewer(
  ownership.viewer,
  ownership.route.id,
);
const initialDiscovery = createAdminInitialSurfaceData(
  await loadAdminData(ownership.viewer),
);

const tabQuery =
  new URL(Astro.request.url).searchParams.get("tab") || "metrics";
const initialTab = [
  "metrics",
  "events",
  "partners",
  "members",
  "add-event",
  "add-partner",
].includes(tabQuery)
  ? tabQuery
  : "metrics";
---

<BaseLayout title="Admin | Unveiled" lang={lang}>
  <VisualSystemApp client:load initialShell={initialShell} initialDiscovery={initialDiscovery} initialView="admin" initialTab={initialTab} />
</BaseLayout>

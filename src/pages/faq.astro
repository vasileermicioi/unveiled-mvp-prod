---
import { VisualSystemApp } from "@/components/unveiled/visual-system-app";
import BaseLayout from "@/layouts/base-layout.astro";
import { createShellFromViewer } from "@/lib/auth-display";
import { getViewer } from "@/lib/auth-profile";
import { loadPublicDiscoveryData } from "@/lib/data-access/loaders";
import { createPublicInitialSurfaceData } from "@/lib/data-access/surface-data";
import { productRoutes, resolveRouteOwnership } from "@/lib/product-routes";

const viewer = await getViewer(Astro.request);
const ownership = resolveRouteOwnership(viewer, productRoutes.faq);
if (!ownership.ok)
  return Astro.redirect(ownership.redirectTo, ownership.status);

const initialShell = createShellFromViewer(
  ownership.viewer,
  ownership.route.id,
);
const initialDiscovery = createPublicInitialSurfaceData(
  await loadPublicDiscoveryData(),
);
---

<BaseLayout title="FAQ | Unveiled">
  <VisualSystemApp
    client:load
    initialShell={initialShell}
    initialDiscovery={initialDiscovery}
    initialView="faq"
    callbackURL={Astro.url.searchParams.get("callbackURL") ?? "/"}
  />
</BaseLayout>

---
import {
  ArrowRight,
  Database,
  Fingerprint,
  Layers3,
  Palette,
} from "lucide-react";

import { Button } from "@/components/ui/button";
import BaseLayout from "@/layouts/base-layout.astro";

const stack = [
  {
    icon: Database,
    title: "Drizzle + Postgres",
    text: "PGlite is used when DATABASE_URL is absent; managed Postgres is used when it is present.",
  },
  {
    icon: Fingerprint,
    title: "Better Auth",
    text: "Mounted at /api/auth/[...all] with Drizzle-backed user, session, account, and verification tables.",
  },
  {
    icon: Palette,
    title: "Tailwind + shadcn/ui",
    text: "Tailwind v4 and shadcn-compatible aliases are ready for copied components.",
  },
  {
    icon: Layers3,
    title: "Astro workbench pages",
    text: "Use /workbench as a lightweight Storybook alternative for UI and integration examples.",
  },
];
---

<BaseLayout title="Unveiled MVP">
  <main class="mx-auto flex min-h-screen w-full max-w-6xl flex-col gap-10 px-6 py-10">
    <nav class="flex items-center justify-between border-b pb-4">
      <a href="/" class="text-sm font-semibold tracking-wide">Unveiled MVP</a>
      <Button asChild variant="outline" size="sm">
        <a href="/workbench">
          Workbench
          <ArrowRight />
        </a>
      </Button>
    </nav>

    <section class="grid gap-6 py-8 md:grid-cols-[1.1fr_0.9fr] md:items-center">
      <div class="grid gap-5">
        <p class="text-sm font-medium text-muted-foreground">Astro application starter</p>
        <h1 class="max-w-3xl text-4xl font-semibold leading-tight md:text-6xl">
          A server-rendered MVP foundation with auth, data, UI, and client state.
        </h1>
        <p class="max-w-2xl text-lg text-muted-foreground">
          The project is configured for Bun, Astro SSR, Drizzle, PGlite local development,
          cloud Postgres, Better Auth, Tailwind, shadcn/ui, Biome, and TanStack Query.
        </p>
        <div class="flex flex-wrap gap-3">
          <Button asChild>
            <a href="/workbench">
              Open workbench
              <ArrowRight />
            </a>
          </Button>
          <Button asChild variant="secondary">
            <a href="/api/health.json">API health</a>
          </Button>
        </div>
      </div>
      <div class="grid gap-3 rounded-lg border bg-card p-5">
        <div class="text-sm font-medium text-muted-foreground">Next commands</div>
        <code class="rounded-md bg-muted p-3 text-sm">bun run db:generate</code>
        <code class="rounded-md bg-muted p-3 text-sm">bun run db:migrate:local</code>
        <code class="rounded-md bg-muted p-3 text-sm">bun run dev</code>
      </div>
    </section>

    <section class="grid gap-4 md:grid-cols-2">
      {
        stack.map((item) => (
          <article class="grid gap-3 rounded-lg border bg-card p-5">
            <item.icon className="size-5 text-primary" />
            <h2 class="text-lg font-semibold">{item.title}</h2>
            <p class="text-sm leading-6 text-muted-foreground">{item.text}</p>
          </article>
        ))
      }
    </section>
  </main>
</BaseLayout>

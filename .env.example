# Better Auth
BETTER_AUTH_SECRET="replace-with-at-least-32-random-characters"
# Local: http://localhost:4321
# Preview/production: the Cloudflare deployment origin.
BETTER_AUTH_URL="http://localhost:4321"
PUBLIC_BETTER_AUTH_URL="http://localhost:4321"

# App / Runtime
PUBLIC_APP_URL="http://localhost:4321"
NODE_ENV="development"
# Optional bearer token for /api/readiness.json in shared environments.
READINESS_TOKEN=""

# Database
# Required in local dev and cloud. Use a Neon/Postgres connection string.
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# Email / Notifications
RESEND_API_KEY=""
DAILY_CODES_FROM_EMAIL=""

# Payments / Subscriptions
# Included if Stripe is selected for membership billing.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_PRICE_BASIC_BERLIN=""
STRIPE_BASIC_BERLIN_MONTHLY_CREDITS="10"
STRIPE_ENABLED_PAYMENT_METHODS="card,sepa_debit,paypal"
PUBLIC_STRIPE_EXPRESS_CHECKOUT_ENABLED="true"
PUBLIC_STRIPE_PAYPAL_ENABLED="true"
PUBLIC_STRIPE_SEPA_ENABLED="true"
PAYMENTS_SUPPORT_EMAIL="support@unveiled.example"
CHECKOUT_SUCCESS_URL="http://localhost:4321/membership?checkout=success"
CHECKOUT_CANCEL_URL="http://localhost:4321/membership?checkout=cancelled"

# Asset Storage
# Included if Cloudflare R2 is selected for event/partner asset uploads.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
# Cloudflare runtime binding name used by wrangler.pages.jsonc: ASSETS_BUCKET
PUBLIC_ASSET_BASE_URL=""

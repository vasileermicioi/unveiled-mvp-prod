# Better Auth
BETTER_AUTH_SECRET="replace-with-at-least-32-random-characters"
BETTER_AUTH_URL="http://localhost:4321"
PUBLIC_BETTER_AUTH_URL="http://localhost:4321"

# App / Runtime
PUBLIC_APP_URL="http://localhost:4321"
NODE_ENV="development"

# Database
# Required in local dev and cloud. Use a Neon/Postgres connection string.
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# Email / Notifications
RESEND_API_KEY=""
DAILY_CODES_FROM_EMAIL=""

# Payments / Subscriptions
# Included if Stripe is selected for membership billing.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_PRICE_BASIC_BERLIN=""

# Asset Storage
# Included if Cloudflare R2 is selected for event/partner asset uploads.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
PUBLIC_ASSET_BASE_URL=""

# Better Auth
BETTER_AUTH_SECRET="replace-with-at-least-32-random-characters"
# Local: http://localhost:4321
# Preview/production: the Cloudflare deployment origin.
BETTER_AUTH_URL="http://localhost:4321"
PUBLIC_BETTER_AUTH_URL="http://localhost:4321"
# Comma-separated list of full origins Better Auth should trust. In dev the
# local proxy hosts are appended automatically; set this in production to the
# Cloudflare deployment origins (e.g. "https://unveiled.com,https://www.unveiled.com").
BETTER_AUTH_TRUSTED_ORIGINS=""
# Public hostname of the orchestrator Worker. Used as the fallback for
# BETTER_AUTH_URL when the secret value is unset (production deploys).
PUBLIC_ORCHESTRATOR_URL="http://localhost:4320"

# App / Runtime
PUBLIC_APP_URL="http://localhost:4321"
NODE_ENV="development"
# Optional bearer token for /api/readiness.json in shared environments.
READINESS_TOKEN=""

# Database
# Required in local dev and cloud. Use a Neon/Postgres connection string.
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# Email / Notifications
RESEND_API_KEY=""
DAILY_CODES_FROM_EMAIL=""

# Payments / Subscriptions
# Included if Stripe is selected for membership billing.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_PRICE_BASIC_BERLIN=""
STRIPE_BASIC_BERLIN_MONTHLY_CREDITS="10"
STRIPE_ENABLED_PAYMENT_METHODS="card,sepa_debit,paypal"
PUBLIC_STRIPE_EXPRESS_CHECKOUT_ENABLED="true"
PUBLIC_STRIPE_PAYPAL_ENABLED="true"
PUBLIC_STRIPE_SEPA_ENABLED="true"
PAYMENTS_SUPPORT_EMAIL="support@unveiled.example"
CHECKOUT_SUCCESS_URL="http://localhost:4321/membership?checkout=success"
CHECKOUT_CANCEL_URL="http://localhost:4321/membership?checkout=cancelled"

# Asset Storage
# Included if Cloudflare R2 is selected for event/partner asset uploads.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
# Cloudflare runtime binding name used by wrangler.pages.jsonc: ASSETS_BUCKET
PUBLIC_ASSET_BASE_URL=""
# Optional. Maximum upload size in bytes for the admin/partner asset upload.
# When unset, the documented default of 5 MB (5242880 bytes) is enforced.
# R2_MAX_UPLOAD_BYTES=""

# Discovery Map
# Optional. The map uses an open tile provider (OpenStreetMap by default)
# and does not require a proprietary API key. Override the tile URL template
# here if you want to point at a different open provider (e.g. CartoDB Voyager).
# Must contain {z}, {x}, {y} placeholders.
# PUBLIC_MAP_TILE_URL="https://tile.openstreetmap.org/{z}/{x}/{y}.png"

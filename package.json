{
  "name": "unveiled-mvp-prod",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "preview:cloudflare": "bun run build && wrangler dev --config dist/server/wrangler.json --remote",
    "deploy:cloudflare": "bun run build && wrangler deploy --config dist/server/wrangler.json",
    "deploy:jobs": "wrangler deploy --config wrangler.jobs.toml",
    "astro": "astro",
    "check": "astro check && biome check . && bun run specs:check && bun run tokens:check && bun run storybook:coverage && bun run scripts/check-no-console.ts",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "specs:gen": "tsp compile typespec/main.tsp && bun run scripts/specs-gen.ts",
    "specs:check": "bun run scripts/specs-check.ts",
    "specs:client:sdk": "echo 'specs:client:sdk reserved for 09-iteration (no-op stub)'",
    "test:e2e": "playwright test --project=real-route tests/parity/gherkin.spec.ts",
    "test:storybook": "playwright test --project=storybook tests/storybook/storybook.spec.ts",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build -o public/storybook",
    "storybook:coverage": "bun tests/storybook/coverage.ts",
    "storybook:test": "concurrently -k -s first -n storybook,test \"bun run storybook\" \"wait-on tcp:6006 && test-storybook --url http://localhost:6006\"",
    "db:seed:operations-smoke": "bun scripts/seed-operations-smoke.ts",
    "arch:check": "likec4 validate && bun run scripts/check-architecture-drift.ts",
    "arch:drift": "bun run scripts/check-architecture-drift.ts",
    "tokens:gen": "bun run scripts/generate-design-tokens.ts",
    "tokens:check": "bun run scripts/check-design-tokens.ts"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.3.1",
    "@astrojs/react": "^5.0.4",
    "@hookform/resolvers": "^5.2.2",
    "@neondatabase/serverless": "^1.1.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@stripe/stripe-js": "^9.4.0",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-query": "^5.100.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.1.9",
    "better-auth": "^1.6.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.11.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.75.0",
    "stripe": "^22.1.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@biomejs/biome": "^2.4.13",
    "@cloudflare/vite-plugin": "1.40.2",
    "@cloudflare/workers-types": "^4.20260506.1",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/react": "^8.6",
    "@storybook/react-vite": "^8.6",
    "@storybook/test": "^8.6.15",
    "@storybook/test-runner": "^0.24.4",
    "@types/bun": "^1.3.13",
    "@types/node": "^25.6.0",
    "@typespec/compiler": "^1.13.0",
    "@typespec/http": "^1.13.0",
    "@typespec/http-server-js": "^0.58.0-alpha.27",
    "@typespec/openapi3": "^1.13.0",
    "concurrently": "^10.0.3",
    "drizzle-kit": "^0.31.10",
    "js-yaml": "^4.2.0",
    "json-schema-to-zod": "^2.6.1",
    "likec4": "^1.0.0",
    "storybook": "^8.6",
    "typescript": "^5.9.3",
    "wait-on": "^9.0.10",
    "wrangler": "^4.88.0"
  },
  "trustedDependencies": [
    "@swc/core",
    "unrs-resolver"
  ]
}

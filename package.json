{
  "name": "unveiled-mvp-prod",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "preview:cloudflare": "bun run build && wrangler dev --config dist/server/wrangler.json --remote",
    "deploy:cloudflare": "bun run build && wrangler deploy --config dist/server/wrangler.json",
    "deploy:jobs": "wrangler deploy --config wrangler.jobs.toml",
    "astro": "astro",
    "check": "astro check && biome check .",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "parity:seed": "bun run scripts/seed-parity-regression.ts",
    "test:parity:contracts": "bun test src/lib/product-routes.test.ts src/lib/data-access/query-layer.test.ts src/lib/parity-fixtures.test.ts src/lib/parity-route-auth.test.ts src/lib/parity-data-access.integration.test.ts src/lib/parity-actions.integration.test.ts src/lib/booking-transactions.integration.test.ts",
    "test:parity:smoke": "bun scripts/run-parity-smoke.ts",
    "test:parity": "bun run test:parity:contracts && bun run test:parity:smoke",
    "test:e2e": "playwright test tests/parity/e2e-gherkin.spec.ts",
    "test:visual": "VISUAL_TESTS=true bun scripts/run-parity-smoke.ts test tests/visual",
    "test:transactions": "bun run scripts/run-booking-transaction-tests.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "bun run scripts/seed-domain-data.ts",
    "db:seed:operations-smoke": "bun scripts/seed-operations-smoke.ts",
    "db:studio": "drizzle-kit studio",
    "jobs:daily-partner-codes": "bun run scripts/run-daily-partner-codes.ts",
    "arch:check": "likec4 validate && bun run scripts/check-architecture-drift.ts",
    "arch:drift": "bun run scripts/check-architecture-drift.ts"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.3.1",
    "@astrojs/react": "^5.0.4",
    "@hookform/resolvers": "^5.2.2",
    "@neondatabase/serverless": "^1.1.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@stripe/stripe-js": "^9.4.0",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-query": "^5.100.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.1.9",
    "better-auth": "^1.6.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.11.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.75.0",
    "stripe": "^22.1.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@biomejs/biome": "^2.4.13",
    "@cloudflare/workers-types": "^4.20260506.1",
    "@playwright/test": "^1.60.0",
    "@types/bun": "^1.3.13",
    "@types/node": "^25.6.0",
    "drizzle-kit": "^0.31.10",
    "likec4": "^1.0.0",
    "typescript": "^5.9.3",
    "wrangler": "^4.88.0"
  }
}
